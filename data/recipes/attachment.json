{
  "id": "attachment",
  "name": "Attachment",
  "description": "Suppressors, optics, muzzle devices, grips, and other weapon attachments",
  "entityType": "GenericEntity",
  "subdirectory": "Prefabs/Weapons/Attachments",
  "defaultParent": "Prefabs/Weapons/Core/Attachment_Base.et",
  "overrideComponents": [
    {
      "type": "MeshObject",
      "properties": { "Object": "" },
      "comment": "Path to attachment .xob model"
    },
    {
      "type": "WeaponAttachmentComponent",
      "properties": { "m_SlotType": "" },
      "comment": "Slot type: muzzle, barrel, receiver, stock, handguard, etc"
    }
  ],
  "postCreateNotes": [
    "Set MeshObject.Object to attachment model",
    "Configure WeaponAttachmentComponent.m_SlotType (must match weapon slot)",
    "Set attachment weight and handling impact if applicable",
    "Configure optical zero/convergence for optics",
    "Test compatibility with at least one base weapon"
  ],
  "variants": [
    {
      "name": "suppressor",
      "description": "Sound suppressors/silencers",
      "defaultParent": "Prefabs/Weapons/Core/Suppressor_Base.et",
      "postCreateNotes": [
        "Set m_SlotType to 'muzzle'",
        "Configure sound reduction (0.7-0.9 multiplier typical)",
        "Set additional weight (~0.3-0.5 kg)"
      ]
    },
    {
      "name": "optic",
      "description": "Weapon sights and scopes",
      "defaultParent": "Prefabs/Weapons/Core/WeaponSight_Base.et",
      "postCreateNotes": [
        "Set m_SlotType to 'sight' or 'scope'",
        "Configure optical magnification (1x for reflex, 4x+ for scope)",
        "Set reticle texture and zero distance",
        "Configure eye relief and field of view"
      ]
    },
    {
      "name": "muzzle_device",
      "description": "Flash hiders, brakes, and compensators",
      "defaultParent": "Prefabs/Weapons/Core/MuzzleDevice_Base.et",
      "postCreateNotes": [
        "Set m_SlotType to 'muzzle'",
        "Configure recoil reduction percentage",
        "Set flash hider effectiveness if applicable",
        "Define muzzle velocity impact"
      ]
    }
  ]
}
